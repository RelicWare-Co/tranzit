{
	"name": "@tranzit/server",
	"scripts": {
		"db:generate": "drizzle-kit generate --config drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
		"db:push": "drizzle-kit push --config drizzle.config.ts",
		"dev": "bun run --env-file ../.env --hot src/index.ts",
		"maildev": "maildev --smtp 1025 --web 1080 --ip 127.0.0.1 --web-ip 127.0.0.1",
		"seed": "bun run --env-file ../.env scripts/seed.ts"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.1",
		"@libsql/client": "^0.17.2",
		"@orpc/server": "^1.13.14",
		"bcryptjs": "^3.0.3",
		"better-auth": "^1.6.1",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.12",
		"hono-pino": "^0.10.3",
		"nodemailer": "^8.0.5",
		"pino": "^10.3.1",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "^3.0.0",
		"@types/bun": "latest",
		"@types/node": "^25.5.2",
		"@types/nodemailer": "^8.0.0",
		"drizzle-kit": "^0.31.10",
		"maildev": "^2.2.1",
		"tsx": "^4.20.6"
	}
}
