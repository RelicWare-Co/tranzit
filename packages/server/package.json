{
	"name": "@tranzit/server",
	"scripts": {
		"db:generate": "drizzle-kit generate --config drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
		"db:push": "drizzle-kit push --config drizzle.config.ts",
		"dev": "bun run --env-file ../.env --hot src/index.ts",
		"maildev": "maildev --smtp 1025 --web 1080 --ip 127.0.0.1 --web-ip 127.0.0.1",
		"seed": "bun run --env-file ../.env scripts/seed.ts",
		"test": "vitest run --maxWorkers=1"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.9",
		"@libsql/client": "^0.17.3",
		"@orpc/server": "^1.14.0",
		"bcryptjs": "^3.0.3",
		"better-auth": "^1.6.9",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"evlog": "^2.14.0",
		"hono": "^4.12.15",
		"nodemailer": "^8.0.7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@better-auth/memory-adapter": "^1.6.9",
		"@better-auth/utils": "^0.4.0",
		"@types/bcryptjs": "^3.0.0",
		"@types/bun": "^1.3.13",
		"@types/node": "^25.6.0",
		"@types/nodemailer": "^8.0.0",
		"drizzle-kit": "^0.31.10",
		"maildev": "^2.2.1",
		"tsx": "^4.21.0",
		"vitest": "^4.1.5"
	}
}
